{
  "name": "sakacode",
  "version": "0.0.24",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pingdotgg/s3code",
    "directory": "apps/server"
  },
  "bin": {
    "s3code": "./dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "node --watch src/bin.ts",
    "build": "node scripts/cli.ts build",
    "build:bundle": "tsdown",
    "start": "node dist/bin.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:process-reaper": "vitest run src/server.test.ts src/provider/Layers/ClaudeAdapter.test.ts src/provider/Layers/ProviderSessionDirectory.test.ts src/provider/Layers/ProviderSessionReaper.test.ts src/provider/Layers/CodexAdapter.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.111",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@github/copilot-sdk": "0.3.0",
    "@opencode-ai/sdk": "^1.3.15",
    "@pierre/diffs": "catalog:",
    "effect": "catalog:",
    "node-pty": "^1.1.0",
    "open": "^10.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@s3tools/contracts": "workspace:*",
    "@s3tools/shared": "workspace:*",
    "@s3tools/tailscale": "workspace:*",
    "@s3tools/web": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "effect-acp": "workspace:*",
    "effect-codex-app-server": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^22.16 || ^23.11 || >=24.10"
  }
}
